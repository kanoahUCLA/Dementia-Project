"""
get_demented_patients.py
========================
Identifies demented patients from final_results_ptinfo.csv.

Usage
-----
    python get_demented_patients.py
"""

import os
import pandas as pd

DATA_PATH = "/Users/noahst.clair/Desktop/dementia/Final Results/final_results_ptinfo.csv"


def get_demented_patients(pt_path: str = DATA_PATH) -> pd.DataFrame:
    """
    Returns all demented patients from ptinfo.

    Parameters
    ----------
    pt_path : Path to final_results_ptinfo.csv

    Returns
    -------
    pd.DataFrame
        Rows where Group == 'Demented'
    """

    df = pd.read_csv(pt_path)

    demented = df[df["Group"] == "Demented"].copy()

    print(f"Total subjects        : {df['Subject ID'].nunique()}")
    print(f"Demented subjects     : {demented['Subject ID'].nunique()}")
    print(f"Demented rows (visits): {len(demented)}")

    return demented


if __name__ == "__main__":
    demented = get_demented_patients()
    print()
    print(demented[["Subject ID", "Group", "Age", "MMSE", "CDR"]].head(10).to_string(index=False))